{
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.md": "${capture}.*.md",
    ".gitattributes": ".gitignore, .gitmessage, .gitmodules",
    ".markdownlint.*": ".markdownlint-cli2.*",
    "AGENTS.md": "CLAUDE.md, GEMINI.md"
  },
  "files.associations": {
    "**/*git/config": "properties",
    "*.tmpl": "go-template",
    "*ignore": "ignore",
    ".gitmessage": "git-commit",
    ".imgbotconfig": "json",
    "dot_curlrc": "shellscript",
    "dot_inputrc": "shellscript",
    "dot_tmux.conf": "properties",
    "dot_vimrc": "viml",
    "dot_wgetrc": "shellscript",
    "pstoprc": "properties",
    "taskrc": "properties",
    "LICENSE": "plaintext"
  },
  "git.branchProtection": ["main"],
  "material-icon-theme.files.associations": {
    "*.tmpl": "template",
    ".imgbotconfig": "robots"
  },
  "yaml.schemas": {
    "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell.schema.json": ".cspell.config.yml",
    "https://storage.googleapis.com/coderabbit_public_assets/schema.v2.json": ".coderabbit.yaml"
  }
}
