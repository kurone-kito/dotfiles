{{- /* Retrieve a Bitwarden attachment content.
     Usage: include "get-secret-attachment" (dict "id" "<item-id>" "name" "<attachment-name>" "manager" .secret_manager)
     For Bitwarden: retrieves an attachment from the specified item
     For 1Password: retrieves document by reference
     For KeePassXC: retrieves attachment by entry name */ -}}
{{- $id := .id -}}
{{- $name := .name -}}
{{- $manager := .manager -}}
{{- if eq $manager "bitwarden" -}}
{{-   bitwardenAttachment $name $id -}}
{{- else if eq $manager "onepassword" -}}
{{-   onepasswordDocument $id -}}
{{- else if eq $manager "keepassxc" -}}
{{-   $db := index . "database" -}}
{{-   keepassxcAttribute $id $name $db -}}
{{- end -}}
