#!/bin/sh
# Import GPG keys from the configured secret manager.
# This script runs once before chezmoi applies the dotfiles.

set -eu

{{ if and (ne .secret_manager "none") .gpg_key_id -}}

echo "Importing GPG keys from {{ .secret_manager }}..."

{{ if eq .secret_manager "bitwarden" -}}
{{ if and (hasKey . "bitwarden") .bitwarden.gpg_public_key_id -}}
echo "Importing GPG public key..."
bw get notes "{{ .bitwarden.gpg_public_key_id }}" | gpg --import 2>/dev/null || true
{{ end -}}

{{ if and (hasKey . "bitwarden") .bitwarden.gpg_private_key_id -}}
echo "Importing GPG private key..."
bw get notes "{{ .bitwarden.gpg_private_key_id }}" | gpg --import 2>/dev/null || true
{{ end -}}
{{ end -}}

{{ if eq .secret_manager "onepassword" -}}
{{ if and (hasKey . "onepassword") .onepassword.gpg_public_key_item -}}
echo "Importing GPG public key..."
op read "{{ .onepassword.gpg_public_key_item }}" | gpg --import 2>/dev/null || true
{{ end -}}

{{ if and (hasKey . "onepassword") .onepassword.gpg_private_key_item -}}
echo "Importing GPG private key..."
op read "{{ .onepassword.gpg_private_key_item }}" | gpg --import 2>/dev/null || true
{{ end -}}
{{ end -}}

{{ if eq .secret_manager "keepassxc" -}}
{{ if and (hasKey . "keepassxc") .keepassxc.gpg_public_key_entry -}}
echo "Importing GPG public key..."
keepassxc-cli show -sa notes "{{ .keepassxc.database }}" "{{ .keepassxc.gpg_public_key_entry }}" | gpg --import 2>/dev/null || true
{{ end -}}

{{ if and (hasKey . "keepassxc") .keepassxc.gpg_private_key_entry -}}
echo "Importing GPG private key..."
keepassxc-cli show -sa notes "{{ .keepassxc.database }}" "{{ .keepassxc.gpg_private_key_entry }}" | gpg --import 2>/dev/null || true
{{ end -}}
{{ end -}}

echo "Setting GPG key trust level..."
echo "{{ .gpg_key_id }}:6:" | gpg --import-ownertrust 2>/dev/null || true

gpgconf --kill gpg-agent 2>/dev/null || true
echo "GPG key import completed."

{{ else -}}
echo "Skipping GPG key import: no secret manager configured or no GPG key ID set."
{{ end -}}
