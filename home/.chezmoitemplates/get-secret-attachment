{{- /* get-secret-attachment: Retrieve a file attachment from the configured manager.
     Usage: {{ template "get-secret-attachment" dict "item" "Item Name" "filename" "key.pem" "ctx" . }}
     - item:     The item name or identifier in the secret manager
                (for local: subdirectory name within local_dir)
     - filename: The attachment filename to retrieve
                (for local: filename within item dir)
     - ctx:      The top-level chezmoi template data (pass . from caller)

     Supported managers: bitwarden, onepassword, keepassxc, local
     Returns empty string when manager is "none" or unrecognized.

     Notes:
     - Bitwarden: uses bitwardenAttachmentByRef to look up by item name
     - 1Password: uses onepasswordDocument (filename is ignored; one
       document per item)
     - KeePassXC: uses keepassxcAttribute with filename as attribute
       name (store base64-encoded content as a named attribute)
     - Local: reads file at local_dir/<item>/<filename> */ -}}
{{- $manager := dig "secret" "manager" "none" .ctx -}}
{{- if eq $manager "bitwarden" -}}
{{-   bitwardenAttachmentByRef .filename "item" .item -}}
{{- else if eq $manager "onepassword" -}}
{{-   onepasswordDocument .item -}}
{{- else if eq $manager "keepassxc" -}}
{{-   keepassxcAttribute .item .filename -}}
{{- else if eq $manager "local" -}}
{{-   template "read-local-file" dict "item" .item "filename" .filename "ctx" .ctx -}}
{{- end -}}
