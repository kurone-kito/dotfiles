{{- /* get-secret: Retrieve a text secret from the configured manager.
     Usage: {{ template "get-secret" dict "item" "Item Name" "field" "password" "ctx" . }}
     - item:  The item name or identifier in the secret manager
             (for local: subdirectory name within local_dir)
     - field: The field to retrieve ("password" for login password,
              or a custom field name; for local: filename within item dir)
     - ctx:   The top-level chezmoi template data (pass . from caller)

     Supported managers: bitwarden, onepassword, keepassxc, local
     Returns empty string when manager is "none" or unrecognized. */ -}}
{{- $manager := dig "secret" "manager" "none" .ctx -}}
{{- warnf "get-secret: manager=%s item=%q field=%q" $manager .item .field -}}
{{- if eq $manager "bitwarden" -}}
{{-   if eq .field "password" -}}
{{-     (bitwarden "item" .item).login.password -}}
{{-   else -}}
{{-     (bitwardenFields "item" .item | dig .field (dict) | dig "value" "") -}}
{{-   end -}}
{{- else if eq $manager "onepassword" -}}
{{-   onepasswordRead (printf "op://%s/%s" .item .field) -}}
{{- else if eq $manager "keepassxc" -}}
{{-   if eq .field "password" -}}
{{-     (keepassxc .item).Password -}}
{{-   else -}}
{{-     keepassxcAttribute .item .field -}}
{{-   end -}}
{{- else if eq $manager "local" -}}
{{-   template "read-local-file" dict "item" .item "filename" .field "ctx" .ctx | trim -}}
{{- end -}}
