#!/usr/bin/env pwsh
# Generated by chezmoi. Do not edit this file directly.
# To manage profiles, edit ~/.config/chezmoi/chezmoi.toml
# and run `chezmoi apply`.
$ErrorActionPreference = 'Stop'

$profilesDir = Join-Path $HOME '.config/git/profiles'
New-Item -ItemType Directory -Path $profilesDir -Force | Out-Null
{{- range $key, $profile := (dig "git" "profiles" dict .) }}
{{- $signingkey := dig "signingkey" "" $profile }}
$profilePath = Join-Path $profilesDir '{{ $key }}'
@'
[user]
  email = {{ $profile.email | quote }}
  name = {{ $profile.name | quote }}
{{- if $signingkey }}
  signingkey = {{ $signingkey | quote }}
[commit]
  gpgsign = true
[tag]
  forceSignAnnotated = true
  gpgsign = true
{{- end }}
'@ | Set-Content -Path $profilePath -Encoding utf8NoBOM
{{- end }}

$validProfiles = @(
{{- range $key, $_ := (dig "git" "profiles" dict .) }}
  '{{ $key }}'
{{- end }}
)

Get-ChildItem -Path $profilesDir -File |
  Where-Object { $validProfiles -notcontains $_.Name } |
  Remove-Item -Force
