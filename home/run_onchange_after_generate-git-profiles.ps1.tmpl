#!/usr/bin/env pwsh
# Generated by chezmoi. Do not edit this file directly.
# To manage profiles, edit ~/.config/chezmoi/chezmoi.toml
# and run `chezmoi apply`.
$ErrorActionPreference = 'Stop'

$profilesDir = Join-Path $HOME '.config/git/profiles'
New-Item -ItemType Directory -Path $profilesDir -Force | Out-Null
{{ template "signing-validate" . -}}
{{ $sshKeys := dig "secret" "ssh" "keys" dict . -}}
{{ $homeDir := replace "\\" "/" .chezmoi.homeDir -}}
{{- range $key, $profile := (dig "git" "profiles" dict .) }}
{{- $signingkey := dig "signingkey" "" $profile -}}
{{- $sshFile := "" -}}
{{- range $label, $k := $sshKeys -}}
{{-   if has $key (dig "signing_profiles" (list) $k) -}}{{ $sshFile = $k.filename }}{{- end -}}
{{- end -}}
{{- $explicitFormat := dig "signing_format" "" $profile -}}
{{- $format := "" -}}
{{- if $explicitFormat -}}{{ $format = $explicitFormat -}}
{{- else if $signingkey -}}{{ $format = "gpg" -}}
{{- else if $sshFile -}}{{ $format = "ssh" -}}
{{- end -}}
{{- $sshAbsPath := "" -}}
{{- if $sshFile -}}{{ $sshAbsPath = printf "%s/.ssh/%s.pub" $homeDir $sshFile -}}{{- end }}
$profilePath = Join-Path $profilesDir '{{ $key }}'
@'
{{- if eq $format "ssh" }}
[gpg]
  format = ssh
{{- end }}
[user]
  email = {{ $profile.email | quote }}
  name = {{ $profile.name | quote }}
{{- if eq $format "ssh" }}
  signingkey = {{ $sshAbsPath | quote }}
[commit]
  gpgsign = true
[tag]
  forceSignAnnotated = true
  gpgsign = true
{{- else if eq $format "gpg" }}
  signingkey = {{ $signingkey | quote }}
[commit]
  gpgsign = true
[tag]
  forceSignAnnotated = true
  gpgsign = true
{{- end }}
{{- if $sshFile }}
[alias]
  commit-ssh = "!f() { git -c 'gpg.format=ssh' -c 'user.signingkey={{ $sshAbsPath }}' -c 'commit.gpgsign=true' commit \"$@\"; }; f \"$@\""
  tag-ssh = "!f() { git -c 'gpg.format=ssh' -c 'user.signingkey={{ $sshAbsPath }}' -c 'tag.gpgsign=true' tag \"$@\"; }; f \"$@\""
  rebase-ssh = "!f() { git -c 'gpg.format=ssh' -c 'user.signingkey={{ $sshAbsPath }}' -c 'commit.gpgsign=true' rebase \"$@\"; }; f \"$@\""
{{- end }}
'@ | Set-Content -Path $profilePath -Encoding utf8NoBOM
{{- end }}

$validProfiles = @(
{{- range $key, $_ := (dig "git" "profiles" dict .) }}
  '{{ $key }}'
{{- end }}
)

Get-ChildItem -Path $profilesDir -File |
  Where-Object { $validProfiles -notcontains $_.Name } |
  Remove-Item -Force
