#!/bin/bash
# chezmoi run_onchange_after script: Deploy user-global secret files
# from the secret manager to home-relative target paths. Re-runs when
# secret content or configuration changes. Skipped when no targets are
# configured or the secret manager is disabled.
set -euo pipefail

# See run_after_99-secret-status-summary.sh.tmpl for rationale.
exec </dev/null

{{ $manager := dig "secret" "manager" "none" . -}}
{{ $files := dig "secret" "files" dict . -}}
{{ if or (not $files) (eq $manager "none") -}}
echo "No secret file targets configured; skipping."
exit 0
{{ end -}}

deploy_state="${HOME}/.local/bin/secret-deploy-state"
record_state() {
  # See run_once_before_20-deploy-ssh-keys.sh.tmpl for the rationale
  # behind closing stdin on the helper invocation.
  [ -x "${deploy_state}" ] || return 0
  "${deploy_state}" record "$1" "$2" "$3" </dev/null || true
}

{{ range $key, $entry := $files -}}
{{ $attachment := dig "attachment" (base $entry.target) $entry -}}
{{ if or (hasPrefix "/" $entry.target) (contains ".." $entry.target) -}}
echo "==> {{ $key }}: SKIPPED — invalid target path (must be relative, no ..)"
{{ else -}}
echo "==> {{ $key }}: ~/{{ $entry.target }}"

target_path="${HOME}/{{ $entry.target }}"
target_dir="$(dirname "${target_path}")"

(umask 077 && mkdir -p "${target_dir}")

cat > "${target_path}" << 'CHEZMOI_SECRET_EOF'
{{ template "get-secret-attachment" dict "item" $entry.item "filename" $attachment "ctx" $ -}}
CHEZMOI_SECRET_EOF

chmod 600 "${target_path}"
echo "  done: deployed (mode 600)"
record_state secretFile "{{ $key }}" "${target_path}"
{{ end -}}

{{ end -}}
echo "secret file deploy complete."
