#!/bin/bash
# Maintain ~/.config/chezmoi/secret-deploy-state.json — a small registry
# of SHA-256 fingerprints for files written by chezmoi secret deploy
# scripts. Used by `secret-status` to detect content drift (manual edits
# made to a deployed secret file after the fact).
#
# The fingerprint is sensitive (it lets an attacker confirm guessed
# plaintext), so the state file is created with mode 600 and lives in
# the same directory as the manifest.
#
# Usage:
#   secret-deploy-state record <category> <name> <absolute-path>
#   secret-deploy-state path
#   secret-deploy-state -h | --help
#
# `record` is best-effort: if hashing fails (e.g., file gone, no sha256
# tool available) the helper logs a warning and exits 0 so the calling
# deploy script is not aborted.
#
# Exit codes:
#   0   recorded successfully (or best-effort skip)
#   2   bad arguments / unsupported environment
set -uo pipefail

STATE_DEFAULT="${HOME}/.config/chezmoi/secret-deploy-state.json"
STATE_PATH="${SECRET_DEPLOY_STATE:-$STATE_DEFAULT}"

usage() { sed -n '2,/^[^#]/{ /^#/s/^# \?//p; }' "$0"; }

warn() { printf 'secret-deploy-state: %s\n' "$*" >&2; }

# Compute SHA-256 of a file. Echoes the hex digest or empty on failure.
_sha256() {
  local path="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$path" 2>/dev/null | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$path" 2>/dev/null | awk '{print $1}'
  else
    return 1
  fi
}

# Echo octal mode of file, or empty if stat unavailable / Windows.
_mode() {
  local path="$1"
  stat -c '%a' "$path" 2>/dev/null || stat -f '%A' "$path" 2>/dev/null || true
}

# Atomic upsert of a single entry (keyed by .path) into the state file.
# Reads JSON from $1 (existing or empty), writes merged JSON to stdout.
_upsert_jq() {
  local existing="$1" category="$2" name="$3" path="$4" sha="$5" mode="$6" ts="$7"
  [ -z "$existing" ] && existing='{"version":1,"entries":[]}'
  printf '%s' "$existing" | jq \
    --arg category "$category" --arg name "$name" --arg path "$path" \
    --arg sha "$sha" --arg mode "$mode" --arg ts "$ts" '
    . as $base |
    ($base.entries // []) as $old |
    {
      version: 1,
      entries: ([
        $old[] | select(.path != $path)
      ] + [{
        category: $category, name: $name, path: $path,
        sha256: $sha, mode: $mode, deployedAt: $ts
      }])
    }'
}

_upsert_python() {
  local existing="$1" category="$2" name="$3" path="$4" sha="$5" mode="$6" ts="$7"
  EXIST="$existing" CAT="$category" NAME="$name" \
  PTH="$path" SHA="$sha" MODE="$mode" TS="$ts" \
    python3 - <<'PY'
import json, os
src = os.environ.get("EXIST", "")
try:
    base = json.loads(src) if src.strip() else {}
except Exception:
    base = {}
entries = [e for e in base.get("entries", []) if e.get("path") != os.environ["PTH"]]
entries.append({
    "category": os.environ["CAT"], "name": os.environ["NAME"],
    "path": os.environ["PTH"], "sha256": os.environ["SHA"],
    "mode": os.environ["MODE"], "deployedAt": os.environ["TS"],
})
print(json.dumps({"version": 1, "entries": entries}, indent=2))
PY
}

cmd_record() {
  if [ "$#" -lt 3 ]; then
    warn "record requires <category> <name> <absolute-path>"
    return 2
  fi
  local category="$1" name="$2" path="$3"

  case "$path" in /*) ;; *)
    warn "record: path must be absolute ($path)"; return 0
  esac

  if [ ! -f "$path" ]; then
    warn "record: file not found, skipping ($path)"
    return 0
  fi

  local sha; sha="$(_sha256 "$path" || true)"
  if [ -z "$sha" ]; then
    warn "record: no sha256 tool available; skipping"
    return 0
  fi
  local mode; mode="$(_mode "$path")"
  local ts; ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo '')"

  local dir; dir="$(dirname "$STATE_PATH")"
  mkdir -p "$dir" 2>/dev/null || { warn "cannot create $dir"; return 0; }

  local existing=""
  if [ -f "$STATE_PATH" ]; then
    existing="$(cat "$STATE_PATH" 2>/dev/null || echo '')"
  fi

  local merged=""
  if command -v jq >/dev/null 2>&1; then
    merged="$(_upsert_jq "$existing" "$category" "$name" "$path" "$sha" "$mode" "$ts")"
  elif command -v python3 >/dev/null 2>&1; then
    merged="$(_upsert_python "$existing" "$category" "$name" "$path" "$sha" "$mode" "$ts")"
  else
    warn "neither jq nor python3 available; skipping"
    return 0
  fi

  if [ -z "$merged" ]; then
    warn "merge produced empty output; skipping"
    return 0
  fi

  local tmp; tmp="$(mktemp "${STATE_PATH}.XXXXXX")" || {
    warn "mktemp failed"; return 0; }
  printf '%s\n' "$merged" >"$tmp" || { rm -f "$tmp"; return 0; }
  chmod 600 "$tmp" 2>/dev/null || true
  mv "$tmp" "$STATE_PATH" || { rm -f "$tmp"; warn "mv failed"; return 0; }
}

if [ "$#" -eq 0 ]; then usage; exit 2; fi
case "$1" in
  -h|--help) usage; exit 0 ;;
  path) printf '%s\n' "$STATE_PATH" ;;
  record) shift; cmd_record "$@" ;;
  *) warn "unknown subcommand: $1"; usage; exit 2 ;;
esac
