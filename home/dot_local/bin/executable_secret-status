#!/bin/bash
# Verify that secrets configured for chezmoi-driven deployment have
# actually landed on disk with the expected paths and permissions.
#
# Reads the manifest rendered by chezmoi at
#   ~/.config/chezmoi/secret-deploy-manifest.json
# (override with --manifest PATH) and prints a colored status table.
#
# Status taxonomy:
#   OK      verified present, correct permissions / keyring entry
#   WARN    present but with the wrong mode or related drift
#   MISSING expected, not found
#   UNKNOWN cannot be verified (manifest field empty or tool absent)
#
# Freshness vs. the secret manager's current contents is intentionally
# NOT checked—use `chezmoi apply` to refresh.
#
# Usage:
#   secret-status [options]
#
# Options:
#   --manifest PATH   Override manifest path
#   --summary         One line per category (used by post-apply hook)
#   --json            Machine-readable JSON output
#   --no-color        Disable color even when stdout is a TTY
#   -h, --help        Show this help
#
# Exit codes:
#   0   all rows OK
#   1   at least one non-OK row (WARN, MISSING, or UNKNOWN)
#   2   manifest unreadable / parse error
set -uo pipefail

usage() {
  sed -n '2,/^[^#]/{ /^#/s/^# \?//p; }' "$0"
}

MANIFEST_DEFAULT="${HOME}/.config/chezmoi/secret-deploy-manifest.json"
MANIFEST="$MANIFEST_DEFAULT"
MODE="table"   # table | summary | json
USE_COLOR="auto"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --manifest)
      [ "$#" -ge 2 ] || { echo "Error: --manifest requires a value." >&2; exit 2; }
      MANIFEST="$2"; shift 2 ;;
    --summary) MODE="summary"; shift ;;
    --json)    MODE="json"; shift ;;
    --no-color) USE_COLOR="never"; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Error: unknown argument '$1'." >&2; usage >&2; exit 2 ;;
  esac
done

# ---------------------------------------------------------------------------
# Color helpers
# ---------------------------------------------------------------------------

if [ "$USE_COLOR" = "auto" ]; then
  if [ -n "${NO_COLOR:-}" ] || [ ! -t 1 ]; then
    USE_COLOR="never"
  else
    USE_COLOR="always"
  fi
fi

if [ "$USE_COLOR" = "always" ]; then
  C_RESET=$'\033[0m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_RED=$'\033[31m'
  C_GRAY=$'\033[90m'
  C_BOLD=$'\033[1m'
else
  C_RESET=''; C_GREEN=''; C_YELLOW=''; C_RED=''; C_GRAY=''; C_BOLD=''
fi

color_for() {
  case "$1" in
    OK) printf '%s' "$C_GREEN" ;;
    WARN) printf '%s' "$C_YELLOW" ;;
    MISSING) printf '%s' "$C_RED" ;;
    UNKNOWN) printf '%s' "$C_GRAY" ;;
    *) printf '' ;;
  esac
}

# ---------------------------------------------------------------------------
# Manifest parsing — prefer jq, fall back to python3
# ---------------------------------------------------------------------------

if [ ! -r "$MANIFEST" ]; then
  echo "secret-status: manifest not found: $MANIFEST" >&2
  echo "  run 'chezmoi apply' to generate it." >&2
  exit 2
fi

if command -v jq >/dev/null 2>&1; then
  PARSER="jq"
elif command -v python3 >/dev/null 2>&1; then
  PARSER="python3"
else
  echo "secret-status: need either jq or python3 to parse manifest." >&2
  exit 2
fi

# Validate manifest is parseable.
if [ "$PARSER" = "jq" ]; then
  jq -e . "$MANIFEST" >/dev/null 2>&1 || {
    echo "secret-status: manifest is not valid JSON: $MANIFEST" >&2; exit 2;
  }
else
  python3 -c "import json,sys; json.load(open(sys.argv[1]))" "$MANIFEST" 2>/dev/null || {
    echo "secret-status: manifest is not valid JSON: $MANIFEST" >&2; exit 2;
  }
fi

# Emit one record per row, using ASCII unit-separator (0x1F) between
# fields so that empty fields are preserved (bash's `read` collapses
# consecutive whitespace IFS, which is why a plain TAB does not work).
extract() {
  local category="$1"
  shift
  local fields="$*"
  if [ "$PARSER" = "jq" ]; then
    # Build a jq array literal of the form [.f1,.f2,...]
    local jq_arr="[" first=1 f
    for f in $fields; do
      [ "$first" -eq 1 ] || jq_arr+=,
      jq_arr+=".$f"
      first=0
    done
    jq_arr+="]"
    jq -r --arg cat "$category" \
      ".categories[\$cat][]? | $jq_arr | map(. // \"\" | tostring) | join(\"\u001f\")" \
      "$MANIFEST"
  else
    python3 - "$MANIFEST" "$category" "$fields" <<'PY'
import json, sys
manifest = json.load(open(sys.argv[1]))
category = sys.argv[2]
fields = sys.argv[3].split()
SEP = '\x1f'
for row in manifest.get('categories', {}).get(category, []) or []:
    vals = []
    for f in fields:
        v = row.get(f, '')
        if v is None:
            v = ''
        vals.append(str(v))
    print(SEP.join(vals))
PY
  fi
}

manifest_field() {
  local path="$1"
  if [ "$PARSER" = "jq" ]; then
    jq -r "$path // \"\"" "$MANIFEST"
  else
    python3 - "$MANIFEST" "$path" <<'PY'
import json, sys
m = json.load(open(sys.argv[1]))
# Support tiny jq path subset: ".a" / ".a.b"
path = sys.argv[2].lstrip('.').split('.')
v = m
for p in path:
    if isinstance(v, dict):
        v = v.get(p, '')
    else:
        v = ''
        break
print('' if v is None else v)
PY
  fi
}

MANIFEST_OS="$(manifest_field .os)"
MANIFEST_HOME="$(manifest_field .homeDir)"
GHQ_ROOT="$(manifest_field .ghqRoot)"
MANAGER="$(manifest_field .manager)"

# ---------------------------------------------------------------------------
# Verifiers
# ---------------------------------------------------------------------------

# Echoes "STATUS\tNOTE" on stdout. Uses STATUS=UNKNOWN when verification
# is impossible.

# Mode check, Unix-only. Echoes the octal mode (e.g. 600) or empty.
file_mode() {
  local path="$1"
  if [ "$MANIFEST_OS" = "windows" ]; then
    return
  fi
  stat -c '%a' "$path" 2>/dev/null || stat -f '%A' "$path" 2>/dev/null
}

verify_gpg() {
  local fpr="$1"
  if [ -z "$fpr" ]; then
    printf 'UNKNOWN\x1fno expected fingerprint configured'
    return
  fi
  if ! command -v gpg >/dev/null 2>&1; then
    printf 'UNKNOWN\x1fgpg not on PATH'
    return
  fi
  if gpg --list-secret-keys "$fpr" >/dev/null 2>&1; then
    printf 'OK\x1fin keyring'
  else
    printf 'MISSING\x1fnot in keyring'
  fi
}

_verify_file_with_mode() {
  local path="$1" want_mode="$2"
  if [ -z "$path" ]; then
    printf 'UNKNOWN\x1fpath not configured'
    return
  fi
  if [ ! -e "$path" ]; then
    printf 'MISSING\x1f%s' "$path"
    return
  fi
  if [ ! -s "$path" ]; then
    printf 'WARN\x1ffile is empty'
    return
  fi
  if [ "$MANIFEST_OS" != "windows" ]; then
    local mode; mode="$(file_mode "$path")"
    if [ -n "$mode" ] && [ -n "$want_mode" ] && [ "$mode" != "$want_mode" ]; then
      printf 'WARN\x1fmode %s, want %s' "$mode" "$want_mode"
      return
    fi
  fi
  printf 'OK\x1f'
}

verify_ssh_key() {
  local priv="$1" pub="$2"
  local res
  res="$(_verify_file_with_mode "$priv" 600)"
  case "$res" in OK*) ;; *) printf '%s' "$res"; return ;; esac
  res="$(_verify_file_with_mode "$pub" 644)"
  case "$res" in OK*) ;; *) printf '%s' "$res"; return ;; esac
  if [ "$MANIFEST_OS" != "windows" ]; then
    local ssh_dir; ssh_dir="$(dirname "$priv")"
    local mode; mode="$(file_mode "$ssh_dir")"
    if [ -n "$mode" ] && [ "$mode" != "700" ]; then
      printf 'WARN\x1f.ssh dir mode %s, want 700' "$mode"
      return
    fi
  fi
  printf 'OK\x1f'
}

verify_ssh_host() {
  local alias="$1" identity_path="$2"
  if ! command -v ssh >/dev/null 2>&1; then
    printf 'UNKNOWN\x1fssh not on PATH'
    return
  fi
  local effective
  effective="$(ssh -G "$alias" 2>/dev/null)"
  if [ -z "$effective" ]; then
    printf 'MISSING\x1falias %s not in ssh config' "$alias"
    return
  fi
  if [ -n "$identity_path" ]; then
    if ! printf '%s\n' "$effective" \
        | awk 'tolower($1)=="identityfile"{print $2}' \
        | grep -Fxq "$identity_path"; then
      printf 'WARN\x1fidentity %s not in effective config' "$identity_path"
      return
    fi
    if [ ! -e "$identity_path" ]; then
      printf 'MISSING\x1fidentity file %s absent' "$identity_path"
      return
    fi
  fi
  printf 'OK\x1f'
}

verify_secret_file() {
  _verify_file_with_mode "$1" 600
}

verify_env_file() {
  local abs_path="$1" repo="$2" filename="$3"
  if [ -z "$abs_path" ]; then
    printf 'UNKNOWN\x1fghq root unresolved'
    return
  fi
  local res; res="$(_verify_file_with_mode "$abs_path" 600)"
  case "$res" in
    OK*) ;;
    *) printf '%s' "$res"; return ;;
  esac
  # Verify the filename is gitignored to prevent accidental commit.
  local repo_root="${abs_path%/$filename}"
  if [ -d "$repo_root/.git" ] || [ -f "$repo_root/.git" ]; then
    if [ -f "$repo_root/.gitignore" ] \
        && ! grep -qxF "$filename" "$repo_root/.gitignore" \
        && ! grep -qxF "/$filename" "$repo_root/.gitignore"; then
      printf 'WARN\x1f%s not in .gitignore' "$filename"
      return
    fi
  fi
  printf 'OK\x1f'
}

# ---------------------------------------------------------------------------
# Aggregation
# ---------------------------------------------------------------------------

# Each row collected as: STATUS\tCATEGORY\tNAME\tTARGET\tNOTE
ROWS=()

collect() {
  ROWS+=("$1")
}

# GPG
while IFS=$'\x1f' read -r label item fingerprint; do
  [ -z "$label" ] && continue
  res="$(verify_gpg "$fingerprint")"
  status="${res%%$'\x1f'*}"
  note="${res#*$'\x1f'}"
  collect "$status"$'\x1f'"GPG"$'\x1f'"$label"$'\x1f'"${fingerprint:-?}"$'\x1f'"$note"
done < <(extract gpg label item fingerprint)

# SSH keys
while IFS=$'\x1f' read -r label item filename priv pub; do
  [ -z "$label" ] && continue
  res="$(verify_ssh_key "$priv" "$pub")"
  status="${res%%$'\x1f'*}"
  note="${res#*$'\x1f'}"
  collect "$status"$'\x1f'"SSHKEY"$'\x1f'"$label"$'\x1f'"$priv"$'\x1f'"$note"
done < <(extract sshKeys label item filename privatePath publicPath)

# SSH hosts
while IFS=$'\x1f' read -r alias hostname user identity identity_path port; do
  [ -z "$alias" ] && continue
  res="$(verify_ssh_host "$alias" "$identity_path")"
  status="${res%%$'\x1f'*}"
  note="${res#*$'\x1f'}"
  collect "$status"$'\x1f'"SSHHOST"$'\x1f'"$alias"$'\x1f'"${hostname}:${port:-22}"$'\x1f'"$note"
done < <(extract sshHosts alias hostname user identity identityPath port)

# Secret files
while IFS=$'\x1f' read -r label item target abs attachment; do
  [ -z "$label" ] && continue
  res="$(verify_secret_file "$abs")"
  status="${res%%$'\x1f'*}"
  note="${res#*$'\x1f'}"
  collect "$status"$'\x1f'"FILE"$'\x1f'"$label"$'\x1f'"$abs"$'\x1f'"$note"
done < <(extract secretFiles label item target absPath attachment)

# Env files
while IFS=$'\x1f' read -r label item repo filename subpath abs attachment; do
  [ -z "$label" ] && continue
  res="$(verify_env_file "$abs" "$repo" "$filename")"
  status="${res%%$'\x1f'*}"
  note="${res#*$'\x1f'}"
  collect "$status"$'\x1f'"ENV"$'\x1f'"$label"$'\x1f'"$abs"$'\x1f'"$note"
done < <(extract envFiles label item repo filename subpath absPath attachment)

# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------

count_status() {
  local want="$1" n=0
  for row in "${ROWS[@]:-}"; do
    [ -z "$row" ] && continue
    [ "${row%%$'\x1f'*}" = "$want" ] && n=$((n + 1))
  done
  printf '%d' "$n"
}

OK_COUNT="$(count_status OK)"
WARN_COUNT="$(count_status WARN)"
MISSING_COUNT="$(count_status MISSING)"
UNKNOWN_COUNT="$(count_status UNKNOWN)"
TOTAL=${#ROWS[@]}

case "$MODE" in
  json)
    if command -v python3 >/dev/null 2>&1; then
      python3 - "$MANAGER" "${ROWS[@]:-}" <<'PY'
import json, sys
manager = sys.argv[1]
rows = []
for r in sys.argv[2:]:
    if not r:
        continue
    parts = r.split('\x1f', 4)
    while len(parts) < 5:
        parts.append('')
    rows.append({
      'status': parts[0], 'category': parts[1], 'name': parts[2],
      'target': parts[3], 'note': parts[4],
    })
print(json.dumps({'manager': manager, 'rows': rows}, indent=2))
PY
    else
      # jq-only fallback. Build JSON by feeding each row to jq via --arg.
      {
        printf '{"manager":'
        printf '%s' "$MANAGER" | jq -Rs .
        printf ',"rows":['
        local_first=1
        for row in "${ROWS[@]:-}"; do
          [ -z "$row" ] && continue
          [ "$local_first" -eq 1 ] || printf ','
          local_first=0
          jq -n -c --arg row "$row" '
            ($row | split("\u001f")) as $f |
            { status: $f[0], category: $f[1], name: $f[2],
              target: $f[3], note: ($f[4] // "") }' </dev/null
        done
        printf ']}\n'
      } | jq .
    fi
    ;;
  summary)
    # One line: OK x / WARN y / MISSING z / UNKNOWN w (total t)
    printf '%ssecret-status%s: ' "$C_BOLD" "$C_RESET"
    printf '%sOK %d%s / %sWARN %d%s / %sMISSING %d%s / %sUNKNOWN %d%s (total %d)\n' \
      "$C_GREEN" "$OK_COUNT" "$C_RESET" \
      "$C_YELLOW" "$WARN_COUNT" "$C_RESET" \
      "$C_RED" "$MISSING_COUNT" "$C_RESET" \
      "$C_GRAY" "$UNKNOWN_COUNT" "$C_RESET" \
      "$TOTAL"
    ;;
  table)
    printf '%sSecret deployment status%s (manager=%s, manifest=%s)\n' \
      "$C_BOLD" "$C_RESET" "${MANAGER:-?}" "$MANIFEST"
    if [ "$TOTAL" -eq 0 ]; then
      printf '  (no deploy targets configured)\n'
    else
      printf '  %-8s %-9s %-22s %-50s %s\n' "STATUS" "CATEGORY" "NAME" "TARGET" "NOTE"
      for row in "${ROWS[@]}"; do
        IFS=$'\x1f' read -r status category name target note <<<"$row"
        local_color="$(color_for "$status")"
        printf '  %s%-8s%s %-9s %-22s %-50s %s\n' \
          "$local_color" "$status" "$C_RESET" \
          "$category" "$name" "$target" "$note"
      done
    fi
    printf '  %sOK %d%s / %sWARN %d%s / %sMISSING %d%s / %sUNKNOWN %d%s\n' \
      "$C_GREEN" "$OK_COUNT" "$C_RESET" \
      "$C_YELLOW" "$WARN_COUNT" "$C_RESET" \
      "$C_RED" "$MISSING_COUNT" "$C_RESET" \
      "$C_GRAY" "$UNKNOWN_COUNT" "$C_RESET"
    ;;
esac

if [ "$WARN_COUNT" -gt 0 ] || [ "$MISSING_COUNT" -gt 0 ] || [ "$UNKNOWN_COUNT" -gt 0 ]; then
  exit 1
fi
exit 0
