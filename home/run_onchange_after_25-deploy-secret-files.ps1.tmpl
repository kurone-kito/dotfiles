# chezmoi run_onchange_after script: Deploy user-global secret files
# from the secret manager to home-relative target paths. Re-runs when
# secret content or configuration changes. Skipped when no targets are
# configured or the secret manager is disabled.

{{ $manager := dig "secret" "manager" "none" . -}}
{{ $files := dig "secret" "files" dict . -}}
{{ if or (not $files) (eq $manager "none") -}}
Write-Host "No secret file targets configured; skipping."
exit 0
{{ end -}}

{{ range $key, $entry := $files -}}
{{ $attachment := dig "attachment" (base $entry.target) $entry -}}
{{ if or (hasPrefix "/" $entry.target) (contains ".." $entry.target) -}}
Write-Host "==> {{ $key }}: SKIPPED — invalid target path (must be relative, no ..)"
{{ else -}}
Write-Host "==> {{ $key }}: ~/{{ $entry.target }}"

$targetPath = Join-Path $HOME '{{ $entry.target }}'
$targetDir = Split-Path -Parent $targetPath

if (-not (Test-Path $targetDir)) {
  New-Item -ItemType Directory -Path $targetDir -Force | Out-Null
  & icacls $targetDir /inheritance:r /grant:r "${env:USERNAME}:(OI)(CI)F" 2>&1 | Out-Null
  if ($LASTEXITCODE -ne 0) {
    Write-Warning "Failed to restrict permissions on ${targetDir} (icacls exit code: $LASTEXITCODE)"
  }
}

@'
{{ template "get-secret-attachment" dict "item" $entry.item "filename" $attachment "ctx" $ -}}
'@ | Set-Content -Path $targetPath -NoNewline -Encoding UTF8

& icacls $targetPath /inheritance:r /grant:r "${env:USERNAME}:(R,W)" 2>&1 | Out-Null
if ($LASTEXITCODE -ne 0) {
  Write-Warning "Failed to restrict permissions on ${targetPath} (icacls exit code: $LASTEXITCODE)"
}
Write-Host "  done: deployed (user-only access)"
{{ end -}}

{{ end -}}
Write-Host "secret file deploy complete."
