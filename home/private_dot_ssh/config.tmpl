# SSH client configuration — generated by chezmoi.
# To modify, edit ~/.local/share/chezmoi/home/private_dot_ssh/config.tmpl
# and run `chezmoi apply`.

# Defaults
Host *
  AddKeysToAgent yes
  IdentitiesOnly yes
{{- if ne .chezmoi.os "windows" }}
  ServerAliveInterval 60
  ServerAliveCountMax 3
{{- end }}

{{ range $alias, $host := (dig "secret" "ssh" "hosts" dict .) -}}
Host {{ $alias }}
  HostName {{ $host.hostname }}
  User {{ dig "user" "git" $host }}
  IdentityFile ~/.ssh/{{ $host.identity }}

{{ end -}}
