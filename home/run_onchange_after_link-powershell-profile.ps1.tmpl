# chezmoi:template:left-delimiter=<% right-delimiter=%>
<%- if eq .chezmoi.os "windows" %>
# Create profile loaders at all possible $PROFILE locations.
# Handles OneDrive redirection, localized Documents folder names,
# and VS Code host-specific profiles by writing shims to every
# known profile path.
#
# hash: <% include "dot_config/powershell/profile.ps1" | sha256sum %>

$loaderContent = @'
# Auto-generated by chezmoi — do not edit directly.
# Real profile: ~/.config/powershell/profile.ps1
$configProfile = Join-Path (Join-Path (Join-Path $HOME '.config') 'powershell') 'profile.ps1'
if (Test-Path $configProfile) { . $configProfile }
'@

# Collect all unique Documents base paths
$docsPaths = @([Environment]::GetFolderPath('MyDocuments'))
$homeDocs = Join-Path $HOME 'Documents'
if (($homeDocs -ne $docsPaths[0]) -and (Test-Path $homeDocs)) {
  $docsPaths += $homeDocs
}

$profileNames = @(
  'profile.ps1',
  'Microsoft.PowerShell_profile.ps1',
  'Microsoft.VSCode_profile.ps1'
)

foreach ($docsBase in $docsPaths) {
  foreach ($subDir in @('PowerShell', 'WindowsPowerShell')) {
    $dir = Join-Path $docsBase $subDir
    if (-not (Test-Path $dir)) {
      New-Item -ItemType Directory -Force -Path $dir | Out-Null
    }
    foreach ($name in $profileNames) {
      $profilePath = Join-Path $dir $name
      Set-Content -Path $profilePath -Value $loaderContent -Force
      Write-Host "Profile loader created: $profilePath"
    }
  }
}
<% end -%>
