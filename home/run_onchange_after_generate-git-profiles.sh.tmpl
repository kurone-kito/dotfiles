#!/bin/bash
# Generated by chezmoi. Do not edit this file directly.
# To manage profiles, edit ~/.config/chezmoi/chezmoi.toml
# and run `chezmoi apply`.
set -euo pipefail

# See run_after_99-secret-status-summary.sh.tmpl for rationale.
exec </dev/null

profiles_dir="${HOME}/.config/git/profiles"
mkdir -p "${profiles_dir}"
{{ template "signing-validate" . -}}
{{ $sshKeys := dig "secret" "ssh" "keys" dict . -}}
{{ range $key, $profile := (dig "git" "profiles" dict .) -}}
{{- $signingkey := dig "signingkey" "" $profile -}}
{{- $sshFile := "" -}}
{{- range $label, $k := $sshKeys -}}
{{-   if has $key (dig "signing_profiles" (list) $k) -}}{{ $sshFile = $k.filename }}{{- end -}}
{{- end -}}
{{- $explicitFormat := dig "signing_format" "" $profile -}}
{{- $format := "" -}}
{{- if $explicitFormat -}}{{ $format = $explicitFormat -}}
{{- else if $sshFile -}}{{ $format = "ssh" -}}
{{- else if $signingkey -}}{{ $format = "gpg" -}}
{{- end }}
cat > "${profiles_dir}/{{ $key }}" << 'PROFILE_EOF'
{{- if eq $format "ssh" }}
[gpg]
  format = ssh
{{- end }}
[user]
  email = {{ $profile.email | quote }}
  name = {{ $profile.name | quote }}
{{- if eq $format "ssh" }}
  signingkey = {{ printf "~/.ssh/%s.pub" $sshFile | quote }}
[commit]
  gpgsign = true
[tag]
  forceSignAnnotated = true
  gpgsign = true
{{- else if eq $format "gpg" }}
  signingkey = {{ $signingkey | quote }}
[commit]
  gpgsign = true
[tag]
  forceSignAnnotated = true
  gpgsign = true
{{- end }}
PROFILE_EOF
{{ end -}}

# Remove orphaned profile files
for f in "${profiles_dir}"/*; do
  [[ -f "${f}" ]] || continue
  case "$(basename "${f}")" in
{{- range $key, $_ := (dig "git" "profiles" dict .) }}
    {{ $key }}) ;;
{{- end }}
    *) rm -f "${f}" ;;
  esac
done
