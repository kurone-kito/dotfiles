# sshd_config — generated by chezmoi.
# To modify, edit ~/.local/share/chezmoi/home/dot_config/ssh/sshd_config.tmpl
# and run `chezmoi apply`.
#
# This file is rendered to ~/.config/ssh/sshd_config (user level).
# Deploy to the system location manually:
#
#   Linux/macOS: sudo cp ~/.config/ssh/sshd_config /etc/ssh/sshd_config
#   Windows:     Copy-Item ~/.config/ssh/sshd_config C:\ProgramData\ssh\sshd_config
#
# Windows administrator accounts use
# C:\ProgramData\ssh\administrators_authorized_keys by default.
# Sync ~/.ssh/authorized_keys with ~/.local/bin/sync-openssh-authorized-keys.ps1
# after key changes.
#
# Then reload sshd:
#
#   Linux:   sudo systemctl reload sshd
#   macOS:   sudo launchctl kickstart -k system/com.openssh.sshd
#   Windows: Restart-Service sshd

{{ $server := dig "ssh" "server" dict . -}}
{{ $clientAliveInterval := dig "clientAliveInterval" 300 $server -}}
{{ $clientAliveCountMax := dig "clientAliveCountMax" 5 $server -}}

# --- Authentication hardening ---

PasswordAuthentication no
PermitEmptyPasswords no
PubkeyAuthentication yes
AuthenticationMethods publickey
PermitRootLogin no

# --- SFTP ---

{{- if eq .chezmoi.os "windows" }}
Subsystem	sftp sftp-server.exe
{{- else }}
Subsystem sftp internal-sftp
{{- end }}

# --- Connection keepalive (mobile-friendly) ---
# Total timeout ≈ ClientAliveInterval × ClientAliveCountMax
# Default: 300s × 5 = ~25 minutes of unresponsive connection

ClientAliveInterval {{ $clientAliveInterval }}
ClientAliveCountMax {{ $clientAliveCountMax }}
TCPKeepAlive yes
