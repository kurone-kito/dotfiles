{{/*
Secret deployment manifest. Rendered at chezmoi apply time and read by
the secret-status command (~/.local/bin/secret-status[.ps1]).

Contains no secret content — only labels, item names, and resolved
target paths. Stored mode 600 via the private_ prefix because item
names and target paths are sensitive metadata.
*/ -}}
{{- $home := .chezmoi.homeDir -}}
{{- $sep := "/" -}}
{{- if eq .chezmoi.os "windows" }}{{ $sep = "\\" }}{{ end -}}
{{- $manager := dig "secret" "manager" "none" . -}}
{{- $primaryFpr := dig "git" "signingkey" "" . -}}
{{- $profiles := dig "git" "profiles" dict . -}}

{{- /* Resolve ghq root once at apply time so the status command does
       not depend on ghq/mise being on PATH. */ -}}
{{- $ghqRoot := "" -}}
{{- if lookPath "ghq" -}}
{{-   $ghqRoot = (output "ghq" "root" | trim) -}}
{{- end -}}

{{- /* GPG entries with fingerprint join. Priority:
       1. explicit fingerprint on the entry,
       2. profile signingkey when label matches a profile,
       3. primary signingkey when there is exactly one gpg entry. */ -}}
{{- $gpgEntries := dig "secret" "gpg" dict . -}}
{{- $gpgList := list -}}
{{- range $label, $entry := $gpgEntries -}}
{{-   $fpr := dig "fingerprint" "" $entry -}}
{{-   if eq $fpr "" -}}
{{-     $profile := dig $label dict $profiles -}}
{{-     $fpr = dig "signingkey" "" $profile -}}
{{-   end -}}
{{-   if and (eq $fpr "") (eq (len $gpgEntries) 1) -}}
{{-     $fpr = $primaryFpr -}}
{{-   end -}}
{{-   $gpgList = append $gpgList (dict
        "label" $label
        "item" (dig "item" "" $entry)
        "fingerprint" $fpr) -}}
{{- end -}}

{{- /* SSH keys. */ -}}
{{- $sshKeyEntries := dig "secret" "ssh" "keys" dict . -}}
{{- $sshKeyList := list -}}
{{- range $label, $entry := $sshKeyEntries -}}
{{-   $filename := dig "filename" "" $entry -}}
{{-   $priv := printf "%s%s.ssh%s%s" $home $sep $sep $filename -}}
{{-   $pub := printf "%s.pub" $priv -}}
{{-   $sshKeyList = append $sshKeyList (dict
        "label" $label
        "item" (dig "item" "" $entry)
        "filename" $filename
        "privatePath" $priv
        "publicPath" $pub) -}}
{{- end -}}

{{- /* SSH hosts. The identity field references a key filename above. */ -}}
{{- $sshHostEntries := dig "secret" "ssh" "hosts" dict . -}}
{{- $sshHostList := list -}}
{{- range $alias, $entry := $sshHostEntries -}}
{{-   $identity := dig "identity" "" $entry -}}
{{-   $idPath := "" -}}
{{-   if ne $identity "" -}}
{{-     $idPath = printf "%s%s.ssh%s%s" $home $sep $sep $identity -}}
{{-   end -}}
{{-   $sshHostList = append $sshHostList (dict
        "alias" $alias
        "hostname" (dig "hostname" "" $entry)
        "user" (dig "user" "git" $entry)
        "identity" $identity
        "identityPath" $idPath
        "port" (dig "port" 0 $entry | int)) -}}
{{- end -}}

{{- /* Secret files (~/.<target>). */ -}}
{{- $secretFileEntries := dig "secret" "files" dict . -}}
{{- $secretFileList := list -}}
{{- range $label, $entry := $secretFileEntries -}}
{{-   $target := dig "target" "" $entry -}}
{{-   $abs := "" -}}
{{-   if ne $target "" -}}
{{-     $native := $target -}}
{{-     if eq $.chezmoi.os "windows" -}}
{{-       $native = replace "/" "\\" $target -}}
{{-     end -}}
{{-     $abs = printf "%s%s%s" $home $sep $native -}}
{{-   end -}}
{{-   $secretFileList = append $secretFileList (dict
        "label" $label
        "item" (dig "item" "" $entry)
        "target" $target
        "absPath" $abs
        "attachment" (dig "attachment" "" $entry)) -}}
{{- end -}}

{{- /* Env files in cloned repos under ghq root. */ -}}
{{- $envEntries := dig "env" "deploy" dict . -}}
{{- $envList := list -}}
{{- range $label, $entry := $envEntries -}}
{{-   $repo := dig "repo" "" $entry -}}
{{-   $filename := dig "filename" ".env" $entry -}}
{{-   $subpath := dig "subpath" "" $entry -}}
{{-   $abs := "" -}}
{{-   if and (ne $ghqRoot "") (ne $repo "") -}}
{{-     $repoNative := $repo -}}
{{-     $subNative := $subpath -}}
{{-     if eq $.chezmoi.os "windows" -}}
{{-       $repoNative = replace "/" "\\" $repo -}}
{{-       $subNative = replace "/" "\\" $subpath -}}
{{-     end -}}
{{-     if ne $subpath "" -}}
{{-       $abs = printf "%s%s%s%s%s%s%s" $ghqRoot $sep $repoNative $sep $subNative $sep $filename -}}
{{-     else -}}
{{-       $abs = printf "%s%s%s%s%s" $ghqRoot $sep $repoNative $sep $filename -}}
{{-     end -}}
{{-   end -}}
{{-   $envList = append $envList (dict
        "label" $label
        "item" (dig "item" "" $entry)
        "repo" $repo
        "filename" $filename
        "subpath" $subpath
        "absPath" $abs
        "attachment" (dig "attachment" "" $entry)) -}}
{{- end -}}

{{- $manifest := dict
      "version" 1
      "manager" $manager
      "os" .chezmoi.os
      "homeDir" $home
      "ghqRoot" $ghqRoot
      "categories" (dict
        "gpg" $gpgList
        "sshKeys" $sshKeyList
        "sshHosts" $sshHostList
        "secretFiles" $secretFileList
        "envFiles" $envList) -}}
{{ $manifest | toPrettyJson }}
