# chezmoi run_after script: print a one-line secret deployment summary
# at the end of every 'chezmoi apply'. Always exits 0 so it never breaks
# the apply pipeline. Skipped when there is nothing to verify.

{{ $manager := dig "secret" "manager" "none" . -}}
{{ $envDeploys := dig "env" "deploy" dict . -}}
{{ if and (eq $manager "none") (not $envDeploys) -}}
exit 0
{{ end -}}

$cmd = Join-Path $HOME (Join-Path '.local' (Join-Path 'bin' 'secret-status.ps1'))
if (-not (Test-Path -LiteralPath $cmd)) { exit 0 }

# Spawn a non-interactive nested pwsh with stdin closed so neither pwsh
# nor any descendant (gpg, ssh, ...) can consume bytes from chezmoi's
# controlling TTY.
try {
  $pwshExe = (Get-Command pwsh -ErrorAction Stop).Source
  $psi = [System.Diagnostics.ProcessStartInfo]::new()
  $psi.FileName = $pwshExe
  $psi.UseShellExecute = $false
  $psi.RedirectStandardInput = $true
  [void]$psi.ArgumentList.Add('-NoLogo')
  [void]$psi.ArgumentList.Add('-NoProfile')
  [void]$psi.ArgumentList.Add('-NonInteractive')
  [void]$psi.ArgumentList.Add('-File')
  [void]$psi.ArgumentList.Add($cmd)
  [void]$psi.ArgumentList.Add('-Summary')
  $proc = [System.Diagnostics.Process]::Start($psi)
  $proc.StandardInput.Close()
  $proc.WaitForExit()
} catch { }
exit 0
